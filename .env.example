# Okta OIDC auth (set on fastmcp.cloud dashboard; optional locally)
# When OKTA_CLIENT_SECRET is unset, the server runs without auth.
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_DOMAIN=https://integrator-9607059.okta.com
OKTA_ISSUER=
MCP_BASE_URL=
JWT_SIGNING_KEY=

