# Okta OIDC auth (set on fastmcp.cloud dashboard; optional locally)
# When OKTA_CLIENT_SECRET is unset, the server runs without auth.
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_DOMAIN=https://integrator-9607059.okta.com
OKTA_ISSUER=
MCP_BASE_URL=
JWT_SIGNING_KEY=

# Per-backend credentials (only set if the backend requires auth).
# Names are referenced from backends.yaml via `token_env:` / ${VAR} interpolation.
# AWS_KNOWLEDGE_BEARER_TOKEN=
# GITHUB_DOCS_BEARER_TOKEN=

# Optional: MCP marketplace discovery endpoint. When set, the server
# pulls docs-tagged MCP servers from this URL at startup and merges
# them with backends.yaml (file entries win on id conflict). Restart
# to re-fetch. Leave unset to disable marketplace discovery entirely.
# MCP_MARKETPLACE_URL=https://robots--mcp-marketplace-web-app.modal.run/api/discovery/servers
#
# For a marketplace-discovered server with bearer auth, set
# <ID>_BEARER_TOKEN (id uppercased with dashes -> underscores).
